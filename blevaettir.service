[Unit]
Description=BleVaettir BLE Sensor Daemon
After=network.target

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/local/bin/blevaettir -d -config /etc/blevaettir/blevaettir.yaml -log-file /var/log/blevaettir.log
Restart=on-failure
RestartSec=5

SupplementaryGroups=bluetooth

[Install]
WantedBy=multi-user.target
