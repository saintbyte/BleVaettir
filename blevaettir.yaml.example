ble:
  hci: 0

storage:
  path: "/var/lib/blevaettir/data.db"

intervals:
  scan_interval_sec: 30

log:
  level: "info"

handlers:
  - type: "db"
    db:
      enabled: true

  - type: "http"
    http:
      enabled: false
      endpoint: "http://localhost:8080/api/sensors"
      api_key: ""

  - type: "narodmon"
    narodmon:
      enabled: false
      endpoint: "http://narodmon.ru/json"
      owner: "Your Name"
      lat: "55.7558"
      lon: "37.6173"
      alt: "150"

  - type: "datacake"
    datacake:
      enabled: false
      endpoint: "https://api.datacake.co"

  - type: "log"

unknown_objects:
  enabled: true
  handlers:
  - type: "log"

  - type: "narodmon"
    narodmon:
      enabled: false
      endpoint: "http://narodmon.com/post"
      device_id: "your_device_id"
      device_mac: "AA:BB:CC:DD:EE:FF"

ble_objects:
  - name: "Kitchen Thermometer"
    mac: "A4:C1:38:12:34:56"
    parsers:
      - type: "xiaomi_lywsd03mmc"
    handlers:
      - type: "db"

  - name: "Living Room"
    mac: "A4:C1:38:AB:CD:EF"
    parsers:
      - type: "atc_thermometer"
    handlers:
      - type: "db"
      - type: "http"

  - name: "Custom Sensor"
    mac: "AA:BB:CC:DD:EE:01"
    parsers:
      - type: "atc_thermometer"
    handlers:
      - type: "http"
        http:
          enabled: true
          endpoint: "http://custom-endpoint.local/api"
          api_key: "custom_api_key"
      - type: "db"

  - name: "Another Sensor"
    mac: "AA:BB:CC:DD:EE:02"
    parsers:
      - type: "xiaomi_lywsd03mmc"
    handlers:
      - type: "narodmon"
        narodmon:
          enabled: true
          endpoint: "http://narodmon.ru/json"
          owner: "Custom Owner"
          lat: "55.7558"
          lon: "37.6173"
          alt: "150"
